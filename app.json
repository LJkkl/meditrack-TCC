{
  "expo": {
    "name": "Meditrack",
    "slug": "meditrack",
    "scheme": "meditrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/capaIcon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/capa.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.luanjardim.meditrack",
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK",
        "DISABLE_KEYGUARD",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/capa.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/notificacao_suave.wav",
            "./assets/notificacao_alerta.wav"
          ]
        }
      ],
      "./plugins/withMeditrackAlarm",
      "@react-native-community/datetimepicker"
    ],
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "55536787-56e4-4ce3-a3da-4034838cad11"
      }
    }
  }
}
